<Window x:Class="Blood_Alcohol.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Blood_Alcohol.Views"
        Title="Blood Alcohol System"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        MinWidth="1000"
        MinHeight="700">

    <Grid>
        <TabControl x:Name="RootTabControl"
                    Background="#F6F8FB"
                    BorderBrush="#CCD8E4"
                    BorderThickness="1"
                    Padding="6">

            <TabItem x:Name="HomeTab"
                     Header="首页">
                <views:HomeView />
            </TabItem>

            <TabItem x:Name="CommunicationTab"
                     Header="通讯配置">
                <views:CommunicationDebugView />
            </TabItem>

            <TabItem x:Name="SettingsTab"
                     Header="设置">
                <views:DebugView />
            </TabItem>

        </TabControl>
    </Grid>
</Window>
