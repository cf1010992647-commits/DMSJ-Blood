<UserControl x:Class="Blood_Alcohol.Views.FaultDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Blood_Alcohol.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="820"
             d:DesignWidth="1400"
             Unloaded="UserControl_Unloaded">
    <UserControl.DataContext>
        <vm:FaultDebugViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="IndustrialButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="Background" Value="#2F6E9E" />
            <Setter Property="BorderBrush" Value="#1E4F73" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource IndustrialButtonStyle}">
            <Setter Property="Background" Value="#64748B" />
            <Setter Property="BorderBrush" Value="#475569" />
        </Style>

        <Style x:Key="CriticalButtonStyle" TargetType="Button" BasedOn="{StaticResource IndustrialButtonStyle}">
            <Setter Property="Background" Value="#B42318" />
            <Setter Property="BorderBrush" Value="#8E1B12" />
        </Style>
    </UserControl.Resources>

    <Grid Background="White" Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#F7F9FC"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" VerticalAlignment="Center">
                    <Button Content="{Binding ClearFaultButtonText}"
                            Width="130"
                            Height="40"
                            Margin="0,0,8,0"
                            Style="{StaticResource CriticalButtonStyle}"
                            Command="{Binding ClearFaultCommand}" />

                    <Button Content="{Binding GlobalShieldButtonText}"
                            Width="150"
                            Height="40"
                            Margin="0,0,8,0"
                            Style="{StaticResource IndustrialButtonStyle}"
                            Command="{Binding ToggleGlobalShieldCommand}" />

                    <Button Content="{Binding SelectedAlarmMaskButtonText}"
                            Width="150"
                            Height="40"
                            Margin="0,0,8,0"
                            Style="{StaticResource IndustrialButtonStyle}"
                            Command="{Binding ToggleSelectedMaskCommand}" />

                    <CheckBox Content="仅显示当前报警"
                              VerticalAlignment="Center"
                              Margin="8,0,12,0"
                              FontSize="14"
                              Foreground="#334155"
                              IsChecked="{Binding ShowActiveOnly}" />

                    <Button Content="清空事件日志"
                            Width="130"
                            Height="40"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ClearEventLogCommand}" />
                </WrapPanel>

                <WrapPanel Grid.Row="1" Margin="0,10,0,0" VerticalAlignment="Center">
                    <TextBlock Text="全局屏蔽位(M):"
                               VerticalAlignment="Center"
                               Foreground="#334155"
                               Margin="0,0,6,0" />
                    <TextBox Text="{Binding GlobalShieldAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Width="80"
                             Height="28"
                             Margin="0,0,12,0" />

                    <Button Content="新增报警点"
                            Command="{Binding AddAlarmPointCommand}"
                            Style="{StaticResource IndustrialButtonStyle}"
                            Margin="0,0,8,0" />
                    <Button Content="删除选中报警点"
                            Command="{Binding DeleteSelectedAlarmCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,0" />
                    <Button Content="重新加载配置"
                            Command="{Binding ReloadConfigCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,0" />
                    <Button Content="保存配置"
                            Command="{Binding SaveConfigCommand}"
                            Style="{StaticResource IndustrialButtonStyle}" />

                    <TextBlock Text="  当前有效报警:"
                               VerticalAlignment="Center"
                               Foreground="#334155"
                               Margin="16,0,4,0" />
                    <TextBlock Text="{Binding ActiveAlarmCount}"
                               VerticalAlignment="Center"
                               Foreground="#B42318"
                               FontWeight="SemiBold"
                               FontSize="16"
                               Margin="0,0,12,0" />
                    <TextBlock Text="屏蔽数:"
                               VerticalAlignment="Center"
                               Foreground="#334155"
                               Margin="0,0,4,0" />
                    <TextBlock Text="{Binding MaskedAlarmCount}"
                               VerticalAlignment="Center"
                               Foreground="#475569"
                               FontWeight="SemiBold"
                               FontSize="16" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="1.3*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#F7F9FC"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10"
                    Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="报警点位列表"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               Margin="0,0,0,8" />

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding AlarmPointsView}"
                              SelectedItem="{Binding SelectedAlarm, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              GridLinesVisibility="Horizontal"
                              AlternationCount="2"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="状态" Width="120" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Ellipse Width="10"
                                                     Height="10"
                                                     Fill="{Binding StateColor}"
                                                     Stroke="#94A3B8"
                                                     Margin="0,0,6,0" />
                                            <TextBlock Text="{Binding StateText}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="地址"
                                                Binding="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                Width="100" />

                            <DataGridTextColumn Header="报警内容"
                                                Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                Width="*" />

                            <DataGridTextColumn Header="报警时间"
                                                Binding="{Binding AlarmTimeText}"
                                                IsReadOnly="True"
                                                Width="170" />

                            <DataGridTemplateColumn Header="屏蔽" Width="70" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="否" />
                                                    <Setter Property="Foreground" Value="#0F172A" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMasked}" Value="True">
                                                            <Setter Property="Text" Value="是" />
                                                            <Setter Property="Foreground" Value="#475569" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="#F7F9FC"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="报警事件记录"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               Margin="0,0,0,8" />

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding AlarmEvents}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              GridLinesVisibility="Horizontal"
                              AlternationCount="2">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="时间"
                                                Binding="{Binding Time, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                                Width="170" />
                            <DataGridTextColumn Header="地址"
                                                Binding="{Binding Address}"
                                                Width="80" />
                            <DataGridTextColumn Header="动作"
                                                Binding="{Binding Action}"
                                                Width="130" />
                            <DataGridTextColumn Header="内容"
                                                Binding="{Binding Description}"
                                                Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#F7F9FC"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="10"
                Padding="10"
                Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#334155"
                       FontSize="14" />
        </Border>
    </Grid>
</UserControl>
