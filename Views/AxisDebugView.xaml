<UserControl x:Class="Blood_Alcohol.Views.AxisDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Blood_Alcohol.ViewModels"
             xmlns:behaviors="clr-namespace:Blood_Alcohol.Views.Behaviors"
             mc:Ignorable="d"
             d:DesignHeight="860"
             d:DesignWidth="1400">
    <UserControl.DataContext>
        <vm:AxisDebugViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="IndustrialActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#1E4F73" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A7FB2" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#285B82" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#AEB9C6" />
                    <Setter Property="BorderBrush" Value="#9AA6B3" />
                    <Setter Property="Foreground" Value="#EEF2F7" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="AxisCardTemplate" DataType="{x:Type vm:AxisControlCardViewModel}">
            <Border Background="#F7F9FC"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14"
                    Margin="0,0,12,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="{Binding Title}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10" />

                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding StatusLamps}"
                                  Margin="0,0,0,12">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,0,14,8">
                                    <Ellipse Width="12"
                                             Height="12"
                                             Fill="{Binding Color}"
                                             Stroke="#94A3B8"
                                             VerticalAlignment="Center"
                                             Margin="0,0,6,0" />
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="#334155"
                                               FontSize="14"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Grid.Row="2" Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="96" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.ColumnSpan="3" Visibility="{Binding ShowPositionFields, Converter={StaticResource BoolToVisibility}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="当前位置 / MM"
                                       Grid.Row="0"
                                       Foreground="#334155"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,8" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Text="{Binding CurrentPosition, UpdateSourceTrigger=PropertyChanged}"
                                     Height="34"
                                     FontSize="18"
                                     Foreground="#0F172A"
                                     Background="White"
                                     BorderBrush="#B8C3D1"
                                     BorderThickness="1"
                                     HorizontalContentAlignment="Center" />

                            <TextBlock Text="目标位置 / MM"
                                       Grid.Row="1"
                                       Foreground="#334155"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Text="{Binding TargetPosition, UpdateSourceTrigger=PropertyChanged}"
                                     Height="34"
                                     FontSize="18"
                                     Foreground="#0F172A"
                                     Background="White"
                                     BorderBrush="#B8C3D1"
                                     BorderThickness="1"
                                     HorizontalContentAlignment="Center" />
                        </Grid>

                        <TextBlock Text="当前手动速度 MM/S"
                                   Grid.Row="2"
                                   Foreground="#334155"
                                   VerticalAlignment="Center"
                                   Margin="0,8,8,8" />
                        <TextBox Grid.Row="2"
                                 Grid.Column="1"
                                 Grid.ColumnSpan="2"
                                 Text="{Binding ManualSpeed, Mode=OneWay}"
                                 Height="34"
                                 FontSize="18"
                                 Foreground="#0F172A"
                                 Background="White"
                                 BorderBrush="#B8C3D1"
                                 BorderThickness="1"
                                 HorizontalContentAlignment="Center"
                                 IsReadOnly="True"
                                 Focusable="False"
                                 Margin="0,8,0,8" />

                        <TextBlock Text="设置手动速度 MM/S"
                                   Grid.Row="3"
                                   Foreground="#334155"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,8" />
                        <TextBox Grid.Row="3"
                                 Grid.Column="1"
                                 Text="{Binding ManualSpeedInput, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34"
                                 FontSize="18"
                                 Foreground="#0F172A"
                                 Background="White"
                                 BorderBrush="#B8C3D1"
                                 BorderThickness="1"
                                 HorizontalContentAlignment="Center"
                                 Margin="0,0,8,8" />
                        <Button Grid.Row="3"
                                Grid.Column="2"
                                Content="写入"
                                Height="34"
                                Margin="0,0,0,8"
                                Style="{StaticResource IndustrialActionButtonStyle}"
                                Command="{Binding WriteManualSpeedCommand}" />

                        <TextBlock Text="当前自动速度 MM/S"
                                   Grid.Row="4"
                                   Foreground="#334155"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,8" />
                        <TextBox Grid.Row="4"
                                 Grid.Column="1"
                                 Grid.ColumnSpan="2"
                                 Text="{Binding AutoSpeed, Mode=OneWay}"
                                 Height="34"
                                 FontSize="18"
                                 Foreground="#0F172A"
                                 Background="White"
                                 BorderBrush="#B8C3D1"
                                 BorderThickness="1"
                                 HorizontalContentAlignment="Center"
                                 IsReadOnly="True"
                                 Focusable="False"
                                 Margin="0,0,0,8" />

                        <TextBlock Text="设置自动速度 MM/S"
                                   Grid.Row="5"
                                   Foreground="#334155"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBox Grid.Row="5"
                                 Grid.Column="1"
                                 Text="{Binding AutoSpeedInput, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34"
                                 FontSize="18"
                                 Foreground="#0F172A"
                                 Background="White"
                                 BorderBrush="#B8C3D1"
                                 BorderThickness="1"
                                 HorizontalContentAlignment="Center"
                                 Margin="0,0,8,0" />
                        <Button Grid.Row="5"
                                Grid.Column="2"
                                Content="写入"
                                Height="34"
                                Style="{StaticResource IndustrialActionButtonStyle}"
                                Command="{Binding WriteAutoSpeedCommand}" />
                    </Grid>

                    <StackPanel Grid.Row="3">
                        <Grid Margin="0,0,0,10"
                              Visibility="{Binding ShowManualLocate, Converter={StaticResource BoolToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="170" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="手动定位值 (MM)"
                                       Foreground="#334155"
                                       VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Height="34"
                                     Text="{Binding ManualLocateInput, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="18"
                                     Foreground="#0F172A"
                                     Background="White"
                                     BorderBrush="#B8C3D1"
                                     BorderThickness="1"
                                     HorizontalContentAlignment="Center"
                                     Margin="0,0,8,0" />
                            <Button Grid.Column="2"
                                    Content="{Binding ManualLocateText}"
                                    Height="34"
                                    Style="{StaticResource IndustrialActionButtonStyle}"
                                    behaviors:ButtonPressBehavior.PressCommand="{Binding ManualLocatePressCommand}"
                                    behaviors:ButtonPressBehavior.ReleaseCommand="{Binding ManualLocateReleaseCommand}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Content="JOG+"
                                    Height="72"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource IndustrialActionButtonStyle}"
                                    behaviors:ButtonPressBehavior.PressCommand="{Binding JogPlusPressCommand}"
                                    behaviors:ButtonPressBehavior.ReleaseCommand="{Binding JogPlusReleaseCommand}"
                                    FontSize="22" />

                            <Button Grid.Column="1"
                                    Content="回原点"
                                    Height="72"
                                    Margin="4,0"
                                    Style="{StaticResource IndustrialActionButtonStyle}"
                                    behaviors:ButtonPressBehavior.PressCommand="{Binding GoHomePressCommand}"
                                    behaviors:ButtonPressBehavior.ReleaseCommand="{Binding GoHomeReleaseCommand}"
                                    FontSize="20" />

                            <Button Grid.Column="2"
                                    Content="JOG-"
                                    Height="72"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource IndustrialActionButtonStyle}"
                                    behaviors:ButtonPressBehavior.PressCommand="{Binding JogMinusPressCommand}"
                                    behaviors:ButtonPressBehavior.ReleaseCommand="{Binding JogMinusReleaseCommand}"
                                    FontSize="22" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="White">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ContentControl Grid.Row="0"
                                Grid.Column="0"
                                Content="{Binding XAxis}"
                                ContentTemplate="{StaticResource AxisCardTemplate}" />

                <ContentControl Grid.Row="0"
                                Grid.Column="1"
                                Content="{Binding YAxis}"
                                ContentTemplate="{StaticResource AxisCardTemplate}" />

                <ContentControl Grid.Row="1"
                                Grid.Column="0"
                                Content="{Binding ZAxis}"
                                ContentTemplate="{StaticResource AxisCardTemplate}" />

                <ContentControl Grid.Row="1"
                                Grid.Column="1"
                                Content="{Binding ShakeAxis}"
                                ContentTemplate="{StaticResource AxisCardTemplate}" />

                <Border Grid.Row="2"
                        Grid.ColumnSpan="2"
                        Background="#F7F9FC"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12">
                    <TextBlock Text="{Binding ActionMessage}" Foreground="#334155" FontSize="15" />
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
