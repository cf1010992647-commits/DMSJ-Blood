<UserControl x:Class="Blood_Alcohol.Views.ParameterConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Blood_Alcohol.ViewModels">
    <UserControl.DataContext>
        <vm:ParameterConfigViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F7F9FC" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="Background" Value="#2F6E9E" />
            <Setter Property="BorderBrush" Value="#1E4F73" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth" Value="100" />
            <Setter Property="Height" Value="34" />
        </Style>
    </UserControl.Resources>

    <Grid Background="White" Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,10">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#334155"
                       FontSize="14" />
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="70" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="加热箱温度" Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource InputBoxStyle}" Text="{Binding HeatingBoxTemperature, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="°C" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" Text="定量环温度" Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource InputBoxStyle}" Text="{Binding QuantitativeLoopTemperature, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Margin="0,10,0,0" Text="°C" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" Text="传输线温度" Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource InputBoxStyle}" Text="{Binding TransferLineTemperature, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" />
                        <TextBlock Grid.Row="2" Grid.Column="2" Margin="0,10,0,0" Text="°C" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,0,0" Text="摇匀时长" Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource InputBoxStyle}" Text="{Binding ShakeDurationSeconds, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="3" Grid.Column="2" Margin="0,10,0,0" Text="s" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="70" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Z轴_丢枪头_上升慢速速度 (D6000)" Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource InputBoxStyle}" Text="{Binding ZDropNeedleRiseSlowSpeed, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="-" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" Text="移液枪吸液延时时间 (D6020)" Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource InputBoxStyle}" Text="{Binding PipetteAspirateDelay100ms, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Margin="0,10,0,0" Text="100ms" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" Text="移液枪打液延时时间 (D6021)" Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource InputBoxStyle}" Text="{Binding PipetteDispenseDelay100ms, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="2" Grid.Column="2" Margin="0,10,0,0" Text="100ms" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,0,0" Text="采血管摇晃原位延时时间 (D6022)" Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource InputBoxStyle}" Text="{Binding TubeShakeHomeDelay100ms, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="3" Grid.Column="2" Margin="0,10,0,0" Text="100ms" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,10,0,0" Text="采血管摇晃工位延时时间 (D6023)" Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="4" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource InputBoxStyle}" Text="{Binding TubeShakeWorkDelay100ms, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="4" Grid.Column="2" Margin="0,10,0,0" Text="100ms" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,10,0,0" Text="采血管摇晃目标次数 (D6024)" Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="5" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource InputBoxStyle}" Text="{Binding TubeShakeTargetCount, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="5" Grid.Column="2" Margin="0,10,0,0" Text="次" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,10,0,0" Text="顶空瓶摇晃原位延时时间 (D6026)" Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="6" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource InputBoxStyle}" Text="{Binding HeadspaceShakeHomeDelay100ms, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="6" Grid.Column="2" Margin="0,10,0,0" Text="100ms" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,10,0,0" Text="顶空瓶摇晃工位延时时间 (D6027)" Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="7" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource InputBoxStyle}" Text="{Binding HeadspaceShakeWorkDelay100ms, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="7" Grid.Column="2" Margin="0,10,0,0" Text="100ms" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center" />

                        <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,10,0,0" Text="顶空瓶摇晃目标次数 (D6028)" Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="8" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource InputBoxStyle}" Text="{Binding HeadspaceShakeTargetCount, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="8" Grid.Column="2" Margin="0,10,0,0" Text="次" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center" />

                        <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,10,0,0" Text="叔丁醇吸液延时时间 (D6030)" Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="9" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource InputBoxStyle}" Text="{Binding ButanolAspirateDelay100ms, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="9" Grid.Column="2" Margin="0,10,0,0" Text="100ms" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center" />

                        <TextBlock Grid.Row="10" Grid.Column="0" Margin="0,10,0,0" Text="叔丁醇打液延时时间 (D6031)" Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="10" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource InputBoxStyle}" Text="{Binding ButanolDispenseDelay100ms, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="10" Grid.Column="2" Margin="0,10,0,0" Text="100ms" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="恢复默认"
                    Style="{StaticResource ActionButtonStyle}"
                    Command="{Binding ResetDefaultCommand}"
                    Margin="0,0,8,0" />
            <Button Content="重新加载"
                    Style="{StaticResource ActionButtonStyle}"
                    Command="{Binding ReloadConfigCommand}"
                    Margin="0,0,8,0" />
            <Button Content="保存参数"
                    Style="{StaticResource ActionButtonStyle}"
                    Command="{Binding SaveConfigCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
