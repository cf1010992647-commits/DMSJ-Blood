<UserControl x:Class="Blood_Alcohol.Views.PointMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Blood_Alcohol.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1400"
             Unloaded="UserControl_Unloaded">
    <UserControl.DataContext>
        <vm:PointMonitorViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="IndustrialButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="Background" Value="#2F6E9E" />
            <Setter Property="BorderBrush" Value="#1E4F73" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource IndustrialButtonStyle}">
            <Setter Property="Background" Value="#64748B" />
            <Setter Property="BorderBrush" Value="#475569" />
        </Style>

        <Style x:Key="MonitorGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="AlternationCount" Value="2" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </UserControl.Resources>

    <Grid Background="White" Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#F7F9FC"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="PLC 点位监控"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#0F172A" />
                    <TextBlock Text="点位来源于 PointMonitorConfig.json，可在界面新增/删除后保存。"
                               FontSize="13"
                               Foreground="#64748B"
                               Margin="0,2,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="新增点位"
                            Command="{Binding AddPointCommand}"
                            Style="{StaticResource IndustrialButtonStyle}"
                            Margin="0,0,8,0" />
                    <Button Content="删除选中"
                            Command="{Binding DeletePointCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,0" />
                    <Button Content="重新加载配置"
                            Command="{Binding ReloadConfigCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,0" />
                    <Button Content="保存配置"
                            Command="{Binding SaveConfigCommand}"
                            Style="{StaticResource IndustrialButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#F7F9FC"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="10"
                Padding="10">
            <DataGrid Style="{StaticResource MonitorGridStyle}"
                      ItemsSource="{Binding Points}"
                      SelectedItem="{Binding SelectedPoint, Mode=TwoWay}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="地址"
                                        Binding="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                        Width="120" />
                    <DataGridTextColumn Header="描述"
                                        Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                        Width="*" />
                    <DataGridTemplateColumn Header="状态" Width="90" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Ellipse Width="12" Height="12" Fill="{Binding StatusColor}" Stroke="#94A3B8" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="操作" Width="180" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Content="开启"
                                            Height="26"
                                            Margin="0,0,4,0"
                                            Command="{Binding DataContext.TogglePointCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource IndustrialButtonStyle}" />
                                    <Button Grid.Column="1"
                                            Content="关闭"
                                            Height="26"
                                            Margin="4,0,0,0"
                                            Command="{Binding DataContext.TogglePointOffCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2"
                Background="#F7F9FC"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="10"
                Padding="10"
                Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#334155"
                       FontSize="14" />
        </Border>
    </Grid>
</UserControl>
