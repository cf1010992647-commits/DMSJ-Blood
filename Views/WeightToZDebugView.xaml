<UserControl x:Class="Blood_Alcohol.Views.WeightToZDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Blood_Alcohol.ViewModels">
    <UserControl.DataContext>
        <vm:WeightToZDebugViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="Background" Value="#2F6E9E" />
            <Setter Property="BorderBrush" Value="#1E4F73" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="Height" Value="34" />
        </Style>
    </UserControl.Resources>

    <Grid Background="White" Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#F7F9FC"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,10">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#334155"
                       FontSize="14" />
        </Border>

        <Border Grid.Row="1"
                Background="#F7F9FC"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Z地址(坐标Json)" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Grid.Column="1"
                         Text="{Binding ZAddress, Mode=OneWay}"
                         Style="{StaticResource InputBoxStyle}"
                         IsReadOnly="True"
                         Focusable="False"
                         Margin="0,0,12,0" />

                <TextBlock Grid.Column="2" Text="Z比例(坐标Json)" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Grid.Column="3"
                         Text="{Binding ZScale, Mode=OneWay, StringFormat=F3}"
                         Style="{StaticResource InputBoxStyle}"
                         IsReadOnly="True"
                         Focusable="False" />

                <WrapPanel Grid.Column="4" HorizontalAlignment="Right">
                    <Button Content="读取当前Z"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding ReadCurrentZCommand}"
                            Margin="0,0,8,0" />
                    <Button Content="加载Json"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding LoadConfigCommand}"
                            Margin="0,0,8,0" />
                    <Button Content="保存Json"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding SaveConfigCommand}" />
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="#F7F9FC"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="当前重量(g)" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Grid.Column="1"
                         Text="{Binding CurrentWeight, StringFormat=F3}"
                         Style="{StaticResource InputBoxStyle}"
                         Margin="0,0,12,0" />

                <TextBlock Grid.Column="2" Text="当前Z(mm)" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Grid.Column="3"
                         Text="{Binding CurrentZ, Mode=OneWay, StringFormat=F3}"
                         Style="{StaticResource InputBoxStyle}"
                         IsReadOnly="True"
                         Focusable="False"
                         Margin="0,0,12,0" />

                <TextBlock Grid.Column="4" Text="目标重量(g)" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Grid.Column="5"
                         Text="{Binding QueryWeight, StringFormat=F3}"
                         Style="{StaticResource InputBoxStyle}" />

                <WrapPanel Grid.Column="6" HorizontalAlignment="Right">
                    <Button Content="计算系数"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding ComputeCoefficientCommand}"
                            Margin="0,0,8,0" />
                    <Button Content="计算目标Z"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding CalculateCommand}" />
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="#F7F9FC"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12">
            <StackPanel>
                <TextBlock Text="{Binding FormulaText}"
                           Foreground="#0F172A"
                           FontWeight="SemiBold"
                           FontSize="15" />

                <TextBlock Margin="0,8,0,0" Foreground="#334155" FontSize="14">
                    <Run Text="系数 Z/重量: " />
                    <Run Text="{Binding ZPerWeight, Mode=OneWay, StringFormat=F6}" />
                </TextBlock>

                <TextBlock Margin="0,4,0,0" Foreground="#334155" FontSize="14">
                    <Run Text="预测Z(mm): " />
                    <Run Text="{Binding PredictedZ, Mode=OneWay, StringFormat=F3}" />
                </TextBlock>

                <TextBlock Margin="0,4,0,0" Foreground="#334155" FontSize="14">
                    <Run Text="发送PLC值(raw): " />
                    <Run Text="{Binding PredictedRawValue, Mode=OneWay}" />
                </TextBlock>

                <WrapPanel Margin="0,10,0,0">
                    <Button Content="测试运动(Z轴)"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding TestMoveCommand}" />
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
