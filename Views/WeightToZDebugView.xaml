<UserControl x:Class="Blood_Alcohol.Views.WeightToZDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Blood_Alcohol.ViewModels">
    <UserControl.DataContext>
        <vm:WeightToZDebugViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="Background" Value="#2F6E9E" />
            <Setter Property="BorderBrush" Value="#1E4F73" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="Height" Value="34" />
        </Style>
    </UserControl.Resources>

    <Grid Background="White" Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#F7F9FC"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,10">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#334155"
                       FontSize="14"
                       TextWrapping="Wrap" />
        </Border>

        <Border Grid.Row="1"
                Background="#F7F9FC"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="重量转Z轴系数"
                           Foreground="#0F172A"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10" />

                <WrapPanel Margin="0,0,0,10">
                    <Button Content="获取重量"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding ReadCurrentWeightCommand}"
                            Margin="0,0,8,8" />
                    <Button Content="获取当前Z轴位置"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding ReadCurrentZCommand}"
                            Margin="0,0,8,8" />
                    <Button Content="计算Z轴系数"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding ComputeCoefficientCommand}"
                            Margin="0,0,8,8" />
                    <Button Content="一键采集计算Z轴系数"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding AcquireAndComputeCoefficientCommand}"
                            MinWidth="180"
                            Margin="0,0,8,8" />
                </WrapPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="White"
                            BorderBrush="#D8E1EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="重量(g)"
                                       Foreground="#64748B"
                                       FontSize="13" />
                            <TextBox Text="{Binding CurrentWeight, Mode=OneWay, StringFormat=F3}"
                                     Style="{StaticResource InputBoxStyle}"
                                     IsReadOnly="True"
                                     Focusable="False"
                                     Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="White"
                            BorderBrush="#D8E1EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Z轴坐标(mm)"
                                       Foreground="#64748B"
                                       FontSize="13" />
                            <TextBox Text="{Binding CurrentZ, Mode=OneWay, StringFormat=F3}"
                                     Style="{StaticResource InputBoxStyle}"
                                     IsReadOnly="True"
                                     Focusable="False"
                                     Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="White"
                            BorderBrush="#D8E1EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="重量转Z系数(mm/g)"
                                       Foreground="#64748B"
                                       FontSize="13" />
                            <TextBox Text="{Binding ZPerWeight, Mode=OneWay, StringFormat=F6}"
                                     Style="{StaticResource InputBoxStyle}"
                                     IsReadOnly="True"
                                     Focusable="False"
                                     Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="#F7F9FC"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="重量转微升系数"
                           Foreground="#0F172A"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10" />

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="获取重量"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding ReadCurrentWeightCommand}"
                            Margin="0,0,8,0" />
                    <TextBox Grid.Column="1"
                             Text="{Binding InputMicroliter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}"
                             Style="{StaticResource InputBoxStyle}"
                             Margin="0,0,8,0" />
                    <TextBlock Grid.Column="2"
                               Text="ul"
                               VerticalAlignment="Center"
                               Foreground="#334155"
                               Margin="0,0,8,0" />
                    <Button Grid.Column="3"
                            Content="计算重量转微升系数"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding ComputeMicroliterCoefficientCommand}" />
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="White"
                            BorderBrush="#D8E1EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="重量(g)"
                                       Foreground="#64748B"
                                       FontSize="13" />
                            <TextBox Text="{Binding CurrentWeight, Mode=OneWay, StringFormat=F3}"
                                     Style="{StaticResource InputBoxStyle}"
                                     IsReadOnly="True"
                                     Focusable="False"
                                     Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="White"
                            BorderBrush="#D8E1EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="输入微升(ul)"
                                       Foreground="#64748B"
                                       FontSize="13" />
                            <TextBox Text="{Binding InputMicroliter, Mode=OneWay, StringFormat=F3}"
                                     Style="{StaticResource InputBoxStyle}"
                                     IsReadOnly="True"
                                     Focusable="False"
                                     Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="White"
                            BorderBrush="#D8E1EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="重量转微升系数(ul/g)"
                                       Foreground="#64748B"
                                       FontSize="13" />
                            <TextBox Text="{Binding MicroliterPerWeight, Mode=OneWay, StringFormat=F6}"
                                     Style="{StaticResource InputBoxStyle}"
                                     IsReadOnly="True"
                                     Focusable="False"
                                     Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="3"
                Background="#F7F9FC"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12">
            <WrapPanel>
                <TextBlock Text="系数配置"
                           Foreground="#334155"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                <Button Content="加载Json"
                        Style="{StaticResource ActionButtonStyle}"
                        Command="{Binding LoadConfigCommand}"
                        Margin="0,0,8,0" />
                <Button Content="保存Json"
                        Style="{StaticResource ActionButtonStyle}"
                        Command="{Binding SaveConfigCommand}" />
            </WrapPanel>
        </Border>
    </Grid>
</UserControl>
