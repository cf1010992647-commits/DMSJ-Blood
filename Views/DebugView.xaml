<UserControl x:Class="Blood_Alcohol.Views.DebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Blood_Alcohol.Views"
             xmlns:vm="clr-namespace:Blood_Alcohol.ViewModels">

    <UserControl.DataContext>
        <vm:DebugViewModel />
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="8,8,8,4"
                Background="#EEF3F8"
                BorderBrush="#C9D5E0"
                BorderThickness="1"
                CornerRadius="6"
                Padding="8,4">
            <TextBlock Text="{Binding ModeHintText}"
                       Foreground="#334155" />
        </Border>

        <TabControl x:Name="DebugTabControl"
                    Grid.Row="1"
                    SelectionChanged="DebugTabControl_OnSelectionChanged"
                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
            <TabItem Header="轴运动调试"
                     IsEnabled="{Binding DataContext.IsManualMode, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     IsHitTestVisible="{Binding DataContext.IsManualMode, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <views:AxisDebugView />
            </TabItem>
            <TabItem Header="点位监控">
                <views:PointMonitorView />
            </TabItem>
            <TabItem Header="故障调试"
                     IsEnabled="{Binding DataContext.IsManualMode, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     IsHitTestVisible="{Binding DataContext.IsManualMode, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <views:FaultDebugView />
            </TabItem>
            <TabItem Header="坐标调试"
                     IsEnabled="{Binding DataContext.IsManualMode, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     IsHitTestVisible="{Binding DataContext.IsManualMode, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <views:CoordinateDebugView />
            </TabItem>
            <TabItem Header="Weight-Z调试"
                     IsEnabled="{Binding DataContext.IsManualMode, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     IsHitTestVisible="{Binding DataContext.IsManualMode, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <views:WeightToZDebugView />
            </TabItem>
            <TabItem Header="参数配置"
                     IsEnabled="{Binding DataContext.IsManualMode, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     IsHitTestVisible="{Binding DataContext.IsManualMode, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <views:ParameterConfigView />
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
