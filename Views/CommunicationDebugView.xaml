<UserControl x:Class="Blood_Alcohol.Views.CommunicationDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Blood_Alcohol.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <UserControl.DataContext>
        <vm:CommunicationViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="IndustrialActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="Background" Value="#2F6E9E" />
            <Setter Property="BorderBrush" Value="#1E4F73" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A7FB2" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#285B82" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#AEB9C6" />
                    <Setter Property="BorderBrush" Value="#9AA6B3" />
                    <Setter Property="Foreground" Value="#EEF2F7" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F7F9FC" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="IndustrialTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource TextBoxStyle}">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#B8C3D1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Height" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="IndustrialComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource ComboBoxStyle}">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#B8C3D1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="Height" Value="30" />
        </Style>
    </UserControl.Resources>

    <Grid Background="White" Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical">
                    <TextBlock Text="通讯调试"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#0F172A" />
                    <TextBlock Text="RS485 / TCP 服务 / 设备端口映射 / 在线日志"
                               FontSize="13"
                               Foreground="#64748B"
                               Margin="0,2,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0">
                    <TextBlock Text="RS485"
                               Foreground="#334155"
                               VerticalAlignment="Center" />
                    <Ellipse Width="10"
                             Height="10"
                             Margin="6,0,12,0"
                             Fill="{Binding Rs485StatusColor}"
                             Stroke="#94A3B8" />
                    <TextBlock Text="TCP"
                               Foreground="#334155"
                               VerticalAlignment="Center" />
                    <Ellipse Width="10"
                             Height="10"
                             Margin="6,0,0,0"
                             Fill="{Binding TcpStatusColor}"
                             Stroke="#94A3B8" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="RS485 通讯"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A" />

                            <TextBlock Text="串口号"
                                       Margin="0,10,0,4"
                                       Foreground="#334155" />
                            <ComboBox ItemsSource="{Binding AvailableComPorts}"
                                      SelectedItem="{Binding SelectedComPort}"
                                      Style="{StaticResource IndustrialComboBoxStyle}" />

                            <TextBlock Text="波特率"
                                       Margin="0,10,0,4"
                                       Foreground="#334155" />
                            <ComboBox ItemsSource="{Binding AvailableBaudRates}"
                                      SelectedItem="{Binding SelectedBaudRate}"
                                      Style="{StaticResource IndustrialComboBoxStyle}" />

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="{Binding Rs485ButtonText}"
                                        Command="{Binding ToggleRs485Command}"
                                        Height="32"
                                        Margin="0,0,4,0"
                                        Style="{StaticResource IndustrialActionButtonStyle}" />
                                <Button Grid.Column="1"
                                        Content="刷新串口"
                                        Command="{Binding RefreshComPortsCommand}"
                                        Height="32"
                                        Margin="4,0,0,0"
                                        Style="{StaticResource IndustrialActionButtonStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="TCP 服务"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A" />

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="监听端口"
                                           VerticalAlignment="Center"
                                           Foreground="#334155"
                                           Margin="0,0,8,0" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding TcpPort}"
                                         Style="{StaticResource IndustrialTextBoxStyle}" />
                                <Button Grid.Column="2"
                                        Content="{Binding TcpButtonText}"
                                        Command="{Binding ToggleTcpCommand}"
                                        Height="32"
                                        Margin="8,0,0,0"
                                        Style="{StaticResource IndustrialActionButtonStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="TCP 设备绑定信息"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A" />

                            <DataGrid ItemsSource="{Binding TcpDevices}"
                                      AutoGenerateColumns="False"
                                      Height="220"
                                      Margin="0,10,0,0"
                                      IsReadOnly="False"
                                      CanUserAddRows="True"
                                      CanUserDeleteRows="True"
                                      CanUserResizeRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0"
                                      Background="White">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="端口"
                                                        Binding="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="90" />
                                    <DataGridTextColumn Header="设备类型"
                                                        Binding="{Binding DeviceType, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="90" />
                                    <DataGridTextColumn Header="DeviceKey"
                                                        Binding="{Binding DeviceKey, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="100" />
                                    <DataGridTextColumn Header="客户端IP"
                                                        Binding="{Binding ClientIp, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <Button Content="保存配置"
                                    Command="{Binding SaveTcpConfigCommand}"
                                    Height="32"
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Right"
                                    MinWidth="96"
                                    Style="{StaticResource IndustrialActionButtonStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="在线测试"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A" />

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Content="测试温度"
                                        Command="{Binding TestTemperatureCommand}"
                                        Height="32"
                                        Margin="0,0,4,0"
                                        Style="{StaticResource IndustrialActionButtonStyle}" />
                                <Button Grid.Column="1"
                                        Content="测试重量"
                                        Command="{Binding TestWeightCommand}"
                                        Height="32"
                                        Margin="4,0,0,0"
                                        Style="{StaticResource IndustrialActionButtonStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="通讯日志"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               Margin="0,0,0,8" />

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Logs}"
                             BorderThickness="0"
                             Background="White">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Foreground="{Binding Color}"
                                           FontFamily="Consolas"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,4">
                                    <Run Text="[" />
                                    <Run Text="{Binding Time}" />
                                    <Run Text="] " />
                                    <Run Text="{Binding Message}" />
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
