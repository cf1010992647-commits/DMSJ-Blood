<UserControl x:Class="Blood_Alcohol.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Blood_Alcohol.ViewModels">
    <UserControl.DataContext>
        <vm:HomeViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <BitmapImage x:Key="IconInit" x:Shared="False" UriSource="/Resources/03初始化_画板 1.png" />
        <BitmapImage x:Key="IconStart1" x:Shared="False" UriSource="/Resources/开始点亮_画板 1.png" />
        <BitmapImage x:Key="IconStart2"
                     x:Shared="False"
                     UriSource="/Resources/开始未点亮_画板 1.png" />
        <BitmapImage x:Key="IconStop1" x:Shared="False" UriSource="/Resources/暂停点亮_画板 1.png" />
        <BitmapImage x:Key="IconStop2"
                     x:Shared="False"
                     UriSource="/Resources/暂停未点亮_画板 1.png" />
        <BitmapImage x:Key="IconSave" x:Shared="False" UriSource="/Resources/41日志窗口管理_画板 1.png" />
        <BitmapImage x:Key="IconLight" x:Shared="False" UriSource="/Resources/灯白.png" />
        <BitmapImage x:Key="IconEmergency" x:Shared="False" UriSource="/Resources/急停点亮_画板 1.png" />
        <BitmapImage x:Key="IconButanol" x:Shared="False" UriSource="/Resources/叔丁醇.png" />
        <BitmapImage x:Key="IconLog"
                     x:Shared="False"
                     UriSource="/Resources/日志图标.png" />
        <BitmapImage x:Key="IconExportLogs"
                     x:Shared="False"
                     UriSource="/Resources/导出日志.png" />
        <BitmapImage x:Key="IconExportchoose"
                     x:Shared="False"
                     UriSource="/Resources/选择路径.png" />
        <BitmapImage x:Key="IconInfo"
                     x:Shared="False"
                     UriSource="/Resources/信息图标.png" />
        <BitmapImage x:Key="IconWarning"
                     x:Shared="False"
                     UriSource="/Resources/警告图标.png" />
        <BitmapImage x:Key="IconError"
                     x:Shared="False"
                     UriSource="/Resources/错误图标.png" />
        <BitmapImage x:Key="IconStandbyMode"
                     x:Shared="False"
                     UriSource="/Resources/待机模式.png" />
        <BitmapImage x:Key="IconPressureMode"
                     x:Shared="False"
                     UriSource="/Resources/压力模式.png" />
        <BitmapImage x:Key="IconExhaustMode"
                     x:Shared="False"
                     UriSource="/Resources/模式.png" />
        <BitmapImage x:Key="IconInjectionMode"
                     x:Shared="False"
                     UriSource="/Resources/注入模式.png" />
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#F7F9FC" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#B8C3D1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="DisplayInput" TargetType="TextBox" BasedOn="{StaticResource Input}">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#0F172A" />
        </Style>

        <Style x:Key="SlotButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="FilterToggle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="Background" Value="#F1F3F5" />
            <Setter Property="BorderBrush" Value="#C7CFDA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E9EDF2" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DDE4EC" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#9CAAC0" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#D9E2EC" />
                    <Setter Property="BorderBrush" Value="#9FB0C3" />
                    <Setter Property="Foreground" Value="#0F172A" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LevelFilterToggle"
               TargetType="ToggleButton"
               BasedOn="{StaticResource FilterToggle}">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="MinWidth" Value="86" />
        </Style>

        <Style x:Key="ModeStateTile" TargetType="Border">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Background" Value="#6B7280" />
        </Style>

        <Style x:Key="LegendDot" TargetType="Ellipse">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Stroke" Value="#475569" />
            <Setter Property="StrokeThickness" Value="0.6" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="TopImageButton" TargetType="Button">
            <Setter Property="Width" Value="74" />
            <Setter Property="Height" Value="74" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#12000000" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#22000000" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="Background" Value="#F2F4F7" />
            <Setter Property="BorderBrush" Value="#C7D0DB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E8EDF3" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#AFBCCB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DCE3EC" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#96A8BC" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="86" />
            <RowDefinition Height="*" />
            <RowDefinition Height="48" />
            <RowDefinition Height="170" />
            <RowDefinition Height="38" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#EDF2F7"
                BorderBrush="#D4DCE4"
                BorderThickness="0,0,0,1">
            <Grid Margin="10,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            Grid.Column="0"
                            VerticalAlignment="Center">
                    <Button Command="{Binding InitCommand}"
                            Style="{StaticResource TopImageButton}">
                        <Button.Content>
                            <StackPanel Orientation="Vertical">
                                <Image Source="{StaticResource IconInit}"
                                       Width="38"
                                       Height="38"
                                       Stretch="Uniform"
                                       Margin="0,0,0,4" />
                                <TextBlock Text="初始化"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#8A8A8A"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center" />
                                <TextBlock Text="系统"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#8A8A8A"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Command="{Binding StartCommand}"
                            Style="{StaticResource TopImageButton}">
                        <Button.Content>
                            <StackPanel Orientation="Vertical">
                                <Image Width="38"
                                       Height="38"
                                       Stretch="Uniform"
                                       Margin="0,0,0,4">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Source" Value="{StaticResource IconStart2}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}"
                                                             Value="True">
                                                    <Setter Property="Source" Value="{StaticResource IconStart1}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="开始"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#8A8A8A"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center" />
                                <TextBlock Text="检测"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#8A8A8A"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Command="{Binding StopCommand}"
                            Style="{StaticResource TopImageButton}">
                        <Button.Content>
                            <StackPanel Orientation="Vertical">
                                <Image Width="38"
                                       Height="38"
                                       Stretch="Uniform"
                                       Margin="0,0,0,4">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Source" Value="{StaticResource IconStop2}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}"
                                                             Value="True">
                                                    <Setter Property="Source" Value="{StaticResource IconStop1}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="停止"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#8A8A8A"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center" />
                                <TextBlock Text="检测"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#8A8A8A"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    
                    <Button Command="{Binding DemoCommand}"
                            Style="{StaticResource TopImageButton}"
                            Margin="0">
                        <Button.Content>
                            <StackPanel Orientation="Vertical">
                                <Image Source="{StaticResource IconEmergency}"
                                       Width="38"
                                       Height="38"
                                       Stretch="Uniform"
                                       Margin="0,0,0,4" />
                                <TextBlock Text="急停"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#8A8A8A"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center" />
                                <TextBlock Text="系统"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#8A8A8A"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>

                <Border Grid.Column="1"
                        BorderBrush="#B8C3D1"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8,4"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        Background="#F8FAFD">
                    <Border.Resources>
                        <Style x:Key="ModeSwitchActionButton" TargetType="Button">
                            <Setter Property="Foreground" Value="#334155" />
                            <Setter Property="Background" Value="#EEF3F8" />
                            <Setter Property="BorderBrush" Value="#C7D3E0" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Padding" Value="14,4" />
                            <Setter Property="Height" Value="30" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Root"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="15">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#E0EBF6" />
                                                <Setter TargetName="Root" Property="BorderBrush" Value="#9FB6D0" />
                                                <Setter Property="Foreground" Value="#0F172A" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#D2E1F0" />
                                                <Setter TargetName="Root" Property="BorderBrush" Value="#8AA7C5" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Root" Property="Background" Value="#2F6FA8" />
                                                <Setter TargetName="Root" Property="BorderBrush" Value="#2F6FA8" />
                                                <Setter Property="Foreground" Value="White" />
                                                <Setter Property="Opacity" Value="1" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Border.Resources>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding ModeDisplayText}"
                                   Foreground="#334155"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Margin="0,0,12,0" />
                        <Button Content="自动"
                                Style="{StaticResource ModeSwitchActionButton}"
                                Command="{Binding SwitchToAutoModeCommand}"
                                IsEnabled="{Binding IsManualMode}"
                                MinWidth="64"
                                Margin="0,0,6,0" />
                        <Button Content="手动"
                                Style="{StaticResource ModeSwitchActionButton}"
                                Command="{Binding SwitchToManualModeCommand}"
                                IsEnabled="{Binding IsAutoMode}"
                                MinWidth="64" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="290" />
                <ColumnDefinition Width="290" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="检材样品转移"
                           FontSize="18"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,8" />
                <Border Grid.Row="1"
                        Style="{StaticResource Card}"
                        Background="#005ECC">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="名称"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding SampleName}"
                                 Style="{StaticResource DisplayInput}" />
                        <TextBlock Grid.Row="1"
                                   Text="体积"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,8,8,0" />
                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Text="{Binding SampleVolume}"
                                 Style="{StaticResource DisplayInput}"
                                 Margin="0,8,0,0" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="2"
                                   Text="μL"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="8,8,0,0" />
                    </Grid>
                </Border>

                <TextBlock Grid.Row="4"
                           Text="叔丁醇加液"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Top"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,8" />
                <Grid Grid.Row="4">
                    <Image Source="{StaticResource IconButanol}"
                           Height="240"
                           Stretch="Uniform"
                           Margin="0,30,0,0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                </Grid>

                <Border Grid.Row="5"
                        Style="{StaticResource Card}" Margin="0,0,0,40"
                        Background="#005ECC">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="名称"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding ButanolName}"
                                 Style="{StaticResource DisplayInput}" />
                        <TextBlock Grid.Row="1"
                                   Text="体积"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,8,8,0" />
                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Text="{Binding ButanolVolume}"
                                 Style="{StaticResource DisplayInput}"
                                 Margin="0,8,0,0" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="2"
                                   Text="μL"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="8,8,0,0" />
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="2"
                  Margin="10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="模式"
                           FontSize="18"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,8" />
                <Border Grid.Row="1"
                        Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Margin="0,0,6,6">
                                <Border.Style>
                                    <Style TargetType="Border"
                                           BasedOn="{StaticResource ModeStateTile}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStandbyProcessMode}" Value="True">
                                                <Setter Property="Background" Value="#22C55E" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="待机模式"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                            </Border>
                            <Border Grid.Column="1"
                                    Margin="6,0,0,6">
                                <Border.Style>
                                    <Style TargetType="Border"
                                           BasedOn="{StaticResource ModeStateTile}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPressureProcessMode}" Value="True">
                                                <Setter Property="Background" Value="#22C55E" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="加压模式"
                                           Foreground="White"
                                           HorizontalAlignment="Center" />
                            </Border>
                            <Border Grid.Row="1"
                                    Margin="0,0,6,0">
                                <Border.Style>
                                    <Style TargetType="Border"
                                           BasedOn="{StaticResource ModeStateTile}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsExhaustProcessMode}" Value="True">
                                                <Setter Property="Background" Value="#22C55E" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="循环/排气"
                                           Foreground="White"
                                           HorizontalAlignment="Center" />
                            </Border>
                            <Border Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="6,0,0,0">
                                <Border.Style>
                                    <Style TargetType="Border"
                                           BasedOn="{StaticResource ModeStateTile}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInjectionProcessMode}" Value="True">
                                                <Setter Property="Background" Value="#22C55E" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="注入模式"
                                           Foreground="White"
                                           HorizontalAlignment="Center" />
                            </Border>
                        </Grid>

                        <Border Grid.Row="1"
                                Margin="0,6,0,0"
                                Background="White"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="6">
                            <Grid Height="110">
                                <Border Margin="1"
                                        Background="#F8FAFC"
                                        BorderBrush="#D6DFEA"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <Image Stretch="Uniform"
                                          >
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Source" Value="{StaticResource IconStandbyMode}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPressureProcessMode}" Value="True">
                                                        <Setter Property="Source" Value="{StaticResource IconPressureMode}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsExhaustProcessMode}" Value="True">
                                                        <Setter Property="Source" Value="{StaticResource IconExhaustMode}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsInjectionProcessMode}" Value="True">
                                                        <Setter Property="Source" Value="{StaticResource IconInjectionMode}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
                <TextBlock Grid.Row="3"
                           Text="移液枪头"
                           FontSize="18"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30" />
                <Border Grid.Row="4" Margin="0,0,0,70"
                        Style="{StaticResource Card}"
                        Padding="6" Background="LightGray">
                    <ItemsControl ItemsSource="{Binding NeedleHeadSlots}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="10" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Ellipse Width="14"
                                         Height="14"
                                         Fill="{Binding Fill}"
                                         Margin="2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource Card}"
                        Background="#005ECC"
                        Margin="30,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="编码"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding ScanCode}"
                                 Style="{StaticResource DisplayInput}" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4*" />
                        <ColumnDefinition Width="6*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="30,0,8,0">
                        <TextBlock Text="采血管架"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,6,0,0">
                            <TextBlock Text="采血管数量"
                                       Foreground="#334155"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />
                            <TextBox Text="{Binding TubeCount, Mode=OneWay}"
                                     Width="64"
                                     Style="{StaticResource DisplayInput}" />
                        </StackPanel>
                        <TextBlock Text="{Binding HeadspaceCount, StringFormat=顶空瓶 {0}}"
                                   Visibility="Collapsed" />
                        <TextBlock Text="{Binding CountRuleText}"
                                   Visibility="Collapsed" />

                        <Border Style="{StaticResource Card}"
                                Margin="0,10,0,0"
                                Background="LightGray">
                            <ItemsControl ItemsSource="{Binding TubeRackSlots}"
                                          IsEnabled="{Binding IsTubeSelectionEnabled}" >
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="5" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource SlotButton}"
                                                Command="{Binding DataContext.TubeRackClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Border Width="37"
                                                    Height="37"
                                                    CornerRadius="17"
                                                    Background="{Binding Fill}"
                                                    BorderBrush="#335A78"
                                                    BorderThickness="1">
                                                <TextBlock Text="{Binding Number}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding Foreground}"
                                                           FontSize="11" />
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Margin="30,0,0,0">
                        <TextBlock Text="顶空瓶架" Margin="0,20,0,0"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   />
                        <Border Style="{StaticResource Card}"
                                Margin="0,24,0,0"
                                Background="LightGray">
                            <ItemsControl ItemsSource="{Binding HeadspaceRackSlots}"
                                          >
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="10" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="37"
                                                Height="37"
                                                CornerRadius="16"
                                                Background="{Binding Fill}"
                                                BorderBrush="#335A78"
                                                BorderThickness="1"
                                                Margin="2">
                                            <TextBlock Text="{Binding Number}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{Binding Foreground}"
                                                       FontSize="10" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
            <StackPanel Grid.Column="3"
                        Margin="8,35,0,0">
                <TextBlock Text="顶空条件"
                           FontSize="18"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,55,8" />
                <Grid Margin="0,25,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ItemsControl Grid.Column="0"
                                  ItemsSource="{Binding Conditions}"
                                  Grid.IsSharedSizeScope="True">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card}"
                                        Background="#005ECC">
                                    <Grid Margin="10,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"
                                                              SharedSizeGroup="ConditionNameColumn" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="Auto"
                                                              SharedSizeGroup="ConditionUnitColumn" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="White"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding Value, Mode=OneWay}"
                                                 Style="{StaticResource DisplayInput}" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Unit}"
                                                   Foreground="White"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Grid.Column="1"
                                Margin="10,80,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse Style="{StaticResource LegendDot}" Fill="#9CA3AF" />
                            <TextBlock Text="分配" VerticalAlignment="Center" Foreground="#334155" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse Style="{StaticResource LegendDot}" Fill="#D1D5DB" />
                            <TextBlock Text="离心" VerticalAlignment="Center" Foreground="#334155" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse Style="{StaticResource LegendDot}" Fill="#7C3AED" />
                            <TextBlock Text="移动" VerticalAlignment="Center" Foreground="#334155" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse Style="{StaticResource LegendDot}" Fill="#16A34A" />
                            <TextBlock Text="完成" VerticalAlignment="Center" Foreground="#334155" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse Style="{StaticResource LegendDot}" Fill="#64748B" />
                            <TextBlock Text="等待" VerticalAlignment="Center" Foreground="#334155" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse Style="{StaticResource LegendDot}" Fill="#4338CA" />
                            <TextBlock Text="限制" VerticalAlignment="Center" Foreground="#334155" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Style="{StaticResource LegendDot}" Fill="#EF4444" />
                            <TextBlock Text="错误" VerticalAlignment="Center" Foreground="#334155" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Background="#DDE5ED"
                BorderBrush="#B7C5D1"
                BorderThickness="0,1,0,1">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <ToggleButton Style="{StaticResource LevelFilterToggle}"
                                  IsChecked="{Binding ShowInfoLogs}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource IconInfo}"
                                   Width="18"
                                   Height="18"
                                   Stretch="Uniform"
                                   Margin="0,0,4,0" />
                            <TextBlock Text="{Binding InfoCount, StringFormat=信息 {0}}"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </ToggleButton>

                    <ToggleButton Style="{StaticResource LevelFilterToggle}"
                                  IsChecked="{Binding ShowWarningLogs}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource IconWarning}"
                                   Width="18"
                                   Height="18"
                                   Stretch="Uniform"
                                   Margin="0,0,4,0" />
                            <TextBlock Text="{Binding WarningCount, StringFormat=警告 {0}}"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </ToggleButton>

                    <ToggleButton Style="{StaticResource LevelFilterToggle}"
                                  IsChecked="{Binding ShowErrorLogs}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource IconError}"
                                   Width="18"
                                   Height="18"
                                   Stretch="Uniform"
                                   Margin="0,0,4,0" />
                            <TextBlock Text="{Binding ErrorCount, StringFormat=错误 {0}}"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </ToggleButton>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding ExportDirectory, StringFormat=导出目录: {0}}"
                           VerticalAlignment="Center"
                           Foreground="#334155"
                           TextTrimming="CharacterEllipsis"
                           Margin="16,0,8,0" />

                <Button Grid.Column="2"
                        Style="{StaticResource LogActionButton}"
                        Command="{Binding SelectExportDirectoryCommand}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        MinWidth="90"
                        Margin="0,0,120,0">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{StaticResource IconExportchoose}"
                               Width="18"
                               Height="18"
                               Stretch="Uniform"
                               Margin="0,0,5,0" />
                        <TextBlock Text="选择路径"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="2"
                        Style="{StaticResource LogActionButton}"
                        Command="{Binding ExportLogsCommand}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        MinWidth="90" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{StaticResource IconExportLogs}"
                               Width="18"
                               Height="18"
                               Stretch="Uniform"
                               Margin="0,0,5,0" />
                        <TextBlock Text="导出日志"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding VisibleLogs}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="时间"
                                    Binding="{Binding Time}"
                                    Width="165" />
                <DataGridTextColumn Header="来源"
                                    Binding="{Binding SourceText}"
                                    Width="90" />
                <DataGridTextColumn Header="日志类型"
                                    Binding="{Binding KindText}"
                                    Width="100" />
                <DataGridTextColumn Header="级别"
                                    Binding="{Binding LevelText}"
                                    Width="70" />
                <DataGridTextColumn Header="采血管"
                                    Binding="{Binding TubeText}"
                                    Width="70" />
                <DataGridTextColumn Header="消息"
                                    Binding="{Binding Message}"
                                    Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="4"
                >
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="8,0">
                <ToggleButton Style="{StaticResource FilterToggle}"
                              IsChecked="{Binding ShowSystemLogs}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{StaticResource IconLog}"
                               Width="18"
                               Height="18"
                               Stretch="Uniform"
                               Margin="0,0,5,0" />
                        <TextBlock Text="系统日志" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Style="{StaticResource FilterToggle}"
                              IsChecked="{Binding ShowProcessLogs}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{StaticResource IconLog}"
                               Width="18"
                               Height="18"
                               Stretch="Uniform"
                               Margin="0,0,5,0" />
                        <TextBlock Text="进程日志" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Style="{StaticResource FilterToggle}"
                              IsChecked="{Binding ShowDebugLogs}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{StaticResource IconLog}"
                               Width="18"
                               Height="18"
                               Stretch="Uniform"
                               Margin="0,0,5,0" />
                        <TextBlock Text="调试日志" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Style="{StaticResource FilterToggle}"
                              IsChecked="{Binding ShowHardwareLogs}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{StaticResource IconLog}"
                               Width="18"
                               Height="18"
                               Stretch="Uniform"
                               Margin="0,0,5,0" />
                        <TextBlock Text="硬件日志" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Style="{StaticResource FilterToggle}"
                              IsChecked="{Binding ShowOperationLogs}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{StaticResource IconLog}"
                               Width="18"
                               Height="18"
                               Stretch="Uniform"
                               Margin="0,0,5,0" />
                        <TextBlock Text="普通操作日志" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Style="{StaticResource FilterToggle}"
                              IsChecked="{Binding ShowDetectionLogs}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{StaticResource IconLog}"
                               Width="18"
                               Height="18"
                               Stretch="Uniform"
                               Margin="0,0,5,0" />
                        <TextBlock Text="检测日志" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>


